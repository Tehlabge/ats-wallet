# ============================================================
# ATS Wallet — переменные для docker-compose / Coolify
# Скопируйте в .env в корне: cp .env.docker.example .env
# ============================================================

# --- PostgreSQL (контейнер postgres) ---
POSTGRES_USER=wallet
POSTGRES_PASSWORD=walletpass
POSTGRES_DB=wallet

# --- Backend (Go API) — подхватывает POSTGRES_* или свои DB_* ---
# Если используете свой Postgres, задайте явно:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USERNAME=wallet
# DB_PASSWORD=walletpass
# DB_DATABASE=wallet
# DB_SSLMODE=disable

JWT_SECRET=ats-wallet-secret-key
ADMIN_JWT_SECRET=ats-admin-secret
CORS_ORIGIN=https://your-domain.com

# Telegram Mini App и бот
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=https://your-domain.com

# TronGrid и кошельки
TRONGRID_API_KEY=
WALLET_PASSWORD=

# Бот техподдержки
SUPPORT_BOT_TOKEN=
SUPPORT_GROUP_ID=-1003782777869

# --- Frontend (опционально) ---
NEXT_PUBLIC_SUPPORT_BOT_USERNAME=supatswallet_bot
