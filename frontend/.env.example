# URL бэкенда. На продакшене при одном домене укажите /api (Next проксирует /api на бэкенд).
# Иначе полный URL: https://ваш-сайт.ru/api  или для разработки  http://localhost:4000
# NEXT_PUBLIC_API_URL=/api

# Отключить телеметрию и проверку версии Next.js (убирает таймаут fetch при старте dev)
# NEXT_TELEMETRY_DISABLED=1

# Вход в админку (проверка в Next.js, без вызова бэкенда). По умолчанию admin / 123123
# Секрет должен совпадать с JWT_SECRET или ADMIN_PASSWORD на бэкенде, чтобы токен принимался.
# ATS_ADMIN_LOGIN=admin
# ATS_ADMIN_PASSWORD=123123
# ATS_ADMIN_JWT_SECRET=ats-admin-secret

# Бот техподдержки в Telegram (без @). Кнопка «Написать в техподдержку» откроет t.me/...
# Можно не задавать — тогда используется значение из API (админка → Бот поддержки) или дефолт supatswallet_bot
NEXT_PUBLIC_SUPPORT_BOT_USERNAME=supatswallet_bot
